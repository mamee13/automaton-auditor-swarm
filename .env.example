# ------------------------------------------------------------------------------
# Automaton Auditor Swarm - Environment Configuration Template
# ------------------------------------------------------------------------------
# Copy this file to .env and fill in your actual keys.
# ------------------------------------------------------------------------------

# [MANDATORY] OpenAI API Key
# Required for: Judicial personas, VisionInspector diagram analysis, and Synthesis.
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# [OPTIONAL] Google API Key
# Used if you want to swap the orchestration model to Gemini.
# Get one at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# [OPTIONAL] Groq API Key
# For ultra-fast inference and free tier (e.g., Llama 3).
# Get one at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# [MANDATORY] OpenRouter API Key
# Required for DeepSeek and high-limit free models.
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# [OPTIONAL] LangSmith Tracing
# Enable this for deep "Judicial Debate" traces and visual debugging of the StateGraph.
# Get one at: https://smith.langchain.com/
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT="automaton-auditor-swarm"

# [OPTIONAL] Anthropic API Key
# For swapping judge personas to Claude models.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
